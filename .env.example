# =============================================================================
# JARVIS Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM Providers ---
# Preferred provider: claude | chatgpt | qwen
JARVIS_LLM_PREFERRED=claude

# Claude: setup-token from `claude setup-token` CLI
JARVIS_CLAUDE_TOKEN=

# ChatGPT: OAuth PKCE (tokens managed automatically after first login)
JARVIS_OPENAI_CLIENT_ID=

# Qwen: Ollama local (no auth needed)
JARVIS_OLLAMA_BASE_URL=http://localhost:11434
JARVIS_OLLAMA_MODEL=qwen3.5:9b

# --- STT (faster-whisper) ---
JARVIS_STT_MODEL=large-v3-turbo
JARVIS_STT_DEVICE=cuda
JARVIS_STT_COMPUTE_TYPE=float16

# --- TTS (Kokoro) ---
JARVIS_TTS_MODEL_PATH=models/kokoro-v1.0.onnx
JARVIS_TTS_VOICES_PATH=models/voices-v1.0.bin
JARVIS_TTS_VOICE=af_sarah
JARVIS_TTS_SPEED=1.0

# --- Wake Word ---
JARVIS_WAKE_WORD=hey jarvis
JARVIS_WAKE_THRESHOLD=0.5

# --- VAD ---
JARVIS_VAD_THRESHOLD=0.5
JARVIS_VAD_SILENCE_MS=300

# --- General ---
JARVIS_LOG_LEVEL=INFO
